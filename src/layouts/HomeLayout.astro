---
import BaseLayout from '@layouts/BaseLayout.astro';
import NavBar     from '@components/navigation/NavBar.astro';
import NavFooter  from '@components/navigation/NavFooter.astro';

export interface Props {
	title: string;
	contentType: string;
	description: string;
	image: string;
}

const { 
    title,
    contentType = "website",
    description,
    image
} = Astro.props as Props;
---

<BaseLayout {title} {contentType} {description} {image}>
    <NavBar />
    <main class="">
        <slot />
    </main>
    <NavFooter />
</BaseLayout>
