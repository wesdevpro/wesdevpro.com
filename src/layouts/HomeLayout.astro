---
import BaseLayout from '@layouts/BaseLayout.astro';

export interface Props {
	title: string;
	contentType: string;
	description: string;
	image: string;
}

const { 
    title,
    contentType = "website",
    description,
    image
} = Astro.props as Props;
---

<BaseLayout {title} {contentType} {description} {image}>
   <h2>NavBar Here :)</h2>
   <main class="">
        <slot />
    </main>
    <h2>Footer Here :) </h2>
</BaseLayout>
