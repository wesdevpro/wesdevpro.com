---
import `@assets/scss/global.scss`
import Seo from '@components/Seo.astro';


interface Props {
    title: string;
	contentType: string;
	description: string;
	image: string;
}

const {
    title,
    contentType = "website",
    description,
    image
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="description" content="Astro description" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <Seo {title} {contentType} {description} url={Astro.url} {image}/>
    </head>
    <body>
        <slot />
    </body>
</html>
